{
   "manifest_version": 3,
   "name": "Serpdigger - 1st Email Extractor",
   "version": "3.1.0",
   "description": "The World's First Elastic Email Scraper",
   "background": {
      "service_worker": "background/service-worker.js"
   },
   "action": {
      "default_icon": {
         "16": "logo/logo-16.png",
         "48": "logo/logo-48.png"
      },
      "default_popup": "popup/popup.html",
      "default_title": "Serpdigger"
   },
   "content_scripts": [ {
      "js": [ "content/patch-worker.js", "includes/jquery.js", "includes/logs.js", "content/duckduckgo.js" ],
      "matches": [ "https://duckduckgo.com/*q=*", "https://cse.google.co.il/*", "https://*/*" ],
      "run_at": "document_end"
   } ],
   "icons": {
      "128": "logo/logo-128.png",
      "16": "logo/logo-16.png",
      "48": "logo/logo-48.png"
   },
   "permissions": [ "storage", "downloads", "tabs", "webNavigation" ],
   "host_permissions": [ "http://*/*", "https://*/*" ],
   "web_accessible_resources": [ {
      "resources": [ "content/worker.js" ],
      "matches": [ "<all_urls>" ]
   } ]
}
